{
  "name": "minesweeper-replay-generator",
  "version": "0.1.0",
  "description": "Browser extension to record minesweeper games and generate .rawvf replay files",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "watch:firefox": "node esbuild.config.mjs --watch --firefox",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/webextension-polyfill": "^0.12.4",
    "esbuild": "^0.27.3",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "webextension-polyfill": "^0.12.0"
  }
}
